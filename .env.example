
# Drive-Thru Ordering VA - Environment Configuration


# 1. Local AI Inference (vLLM / Ollama)
# If running your own local models, point to your local server.
# Example for vLLM or Ollama OpenAI-compatible endpoint:
LLM_API_URL="http://localhost:11434/v1/chat/completions"
# Local inference usually doesn't need an API key, but you can set a dummy one.
GROQ_API_KEY="your_groq_api_key_here"
LLM_API_KEY="sk-dummy-key"

# 2. Cloud AI Fallback (Optional)
# If you decide to use Groq for ultra-fast Llama-3 inference instead of local hosting:
# LLM_API_URL="https://api.groq.com/openai/v1/chat/completions"

# 3. Application Settings
HOST="0.0.0.0"
PORT="8000"
ENVIRONMENT="development" # or "production"
